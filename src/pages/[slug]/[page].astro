---
import { getSiteBySlug, getSitePages, getPageComponents, getUserProjects } from "../../lib/supabase";
import type { SiteComponent, Project, BodyConfig, ProjectColumnsConfig, RichTextConfig, SeparatorConfig, FigureConfig } from "../../types";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import ProjectList from "../../components/ProjectList.astro";
import CTA from "../../components/CTA.astro";
import Body from "../../components/Body.astro";
import Content from "../../components/Content.astro";
import LegalPage from "../../components/LegalPage.astro";
import ProjectColumns from "../../components/ProjectColumns.astro";
import RichText from "../../components/RichText.astro";
import Figure from "../../components/Figure.astro";

const { slug, page: pageSlug } = Astro.params;

const site = await getSiteBySlug(slug!);

if (!site) {
  return Astro.redirect('/404');
}

const pages = await getSitePages(site.id);
const currentPage = pages.find((p) => p.slug === pageSlug);

if (!currentPage) {
  return Astro.redirect('/404');
}

const isLegal = currentPage.slug === "aviso-legal" || currentPage.slug === "politica-cookies";

const LEGAL_TITLES: Record<string, string> = {
  "aviso-legal": "Legal Notice",
  "politica-cookies": "Cookie Policy",
};

const components = isLegal ? [] : await getPageComponents(currentPage.id);

let projects: Project[] = [];
const needsProjects = currentPage.slug === "proyectos" || components.some((c) => c.type === "project_columns");
if (needsProjects) {
  projects = await getUserProjects(site.user_id);
}

const projectListComp = components.find((c) => c.type === "project_list");
const projectListLayout = (projectListComp?.config as any)?.layout ?? "grid-4";
const projectOrder: string[] = (projectListComp?.config as any)?.project_order ?? [];
const hiddenProjects: string[] = (projectListComp?.config as any)?.hidden_projects ?? [];

if (hiddenProjects.length > 0) {
  const hiddenSet = new Set(hiddenProjects.map(String));
  projects = projects.filter((p) => !hiddenSet.has(String(p.id)));
}

if (projectOrder.length > 0) {
  const orderMap = new Map(projectOrder.map((id, i) => [String(id), i]));
  projects.sort((a, b) => {
    const ai = orderMap.get(String(a.id));
    const bi = orderMap.get(String(b.id));
    if (ai !== undefined && bi !== undefined) return ai - bi;
    if (ai !== undefined) return -1;
    if (bi !== undefined) return 1;
    return Number(b.id) - Number(a.id);
  });
} else {
  projects.sort((a, b) => Number(b.id) - Number(a.id));
}
---

<BaseLayout site={site} pages={pages} currentPageSlug={currentPage.slug}>
  {isLegal ? (
    <LegalPage title={LEGAL_TITLES[currentPage.slug] ?? currentPage.title} content={currentPage.content} />
  ) : (
    <div class="flex flex-col gap-8">
      {components.map((component) => {
        if (component.type === "header") {
          return <Header config={component.config as any} />;
        }
        if (component.type === "cta") {
          return <CTA config={component.config as any} />;
        }
        if (component.type === "body") {
          return <Body config={component.config as BodyConfig} />;
        }
        if (component.type === "content") {
          return <Content config={component.config as any} primaryColor={site.primary_color} secondaryColor={site.secondary_color} />;
        }
        if (component.type === "project_columns") {
          return <ProjectColumns config={component.config as ProjectColumnsConfig} projects={projects} siteSlug={site.slug} />;
        }
        if (component.type === "rich_text") {
          return <RichText config={component.config as RichTextConfig} />;
        }
        if (component.type === "separator") {
          const sizeMap = { small: "40px", medium: "80px", large: "128px" };
          const { size } = component.config as SeparatorConfig;
          return <div data-component="separator" style={`height:${sizeMap[size] ?? "80px"}`} />;
        }
        if (component.type === "figure") {
          return <Figure config={component.config as FigureConfig} />;
        }
        return null;
      })}

      {currentPage.slug === "proyectos" && (
        <ProjectList projects={projects} siteSlug={site.slug} layout={projectListLayout} fullWidth={!!site.full_width} />
      )}
    </div>
  )}
</BaseLayout>
