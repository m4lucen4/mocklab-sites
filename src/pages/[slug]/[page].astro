---
import { getSiteBySlug, getSitePages, getPageComponents, getUserProjects } from "../../lib/supabase";
import type { SiteComponent, Project, BodyConfig } from "../../types";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import ProjectList from "../../components/ProjectList.astro";
import CTA from "../../components/CTA.astro";
import Body from "../../components/Body.astro";
import Content from "../../components/Content.astro";
import LegalPage from "../../components/LegalPage.astro";

const { slug, page: pageSlug } = Astro.params;

const site = await getSiteBySlug(slug!);

if (!site) {
  return Astro.redirect('/404');
}

const pages = await getSitePages(site.id);
const currentPage = pages.find((p) => p.slug === pageSlug);

if (!currentPage) {
  return Astro.redirect('/404');
}

const isLegal = currentPage.slug === "aviso-legal" || currentPage.slug === "politica-cookies";

const components = isLegal ? [] : await getPageComponents(currentPage.id);

let projects: Project[] = [];
if (currentPage.slug === "proyectos") {
  projects = await getUserProjects(site.user_id);
}

const projectListComp = components.find((c) => c.type === "project_list");
const projectListLayout = (projectListComp?.config as any)?.layout ?? "grid-4";
const projectOrder: string[] = (projectListComp?.config as any)?.project_order ?? [];

if (projectOrder.length > 0) {
  const orderMap = new Map(projectOrder.map((id, i) => [String(id), i]));
  projects.sort((a, b) => {
    const ai = orderMap.get(String(a.id));
    const bi = orderMap.get(String(b.id));
    if (ai !== undefined && bi !== undefined) return ai - bi;
    if (ai !== undefined) return -1;
    if (bi !== undefined) return 1;
    return Number(b.id) - Number(a.id);
  });
} else {
  projects.sort((a, b) => Number(b.id) - Number(a.id));
}
---

<BaseLayout site={site} pages={pages} currentPageSlug={currentPage.slug}>
  {isLegal ? (
    <LegalPage title={currentPage.title} content={currentPage.content} />
  ) : (
    <>
      {components.map((component) => {
        if (component.type === "header") {
          return <Header config={component.config as any} />;
        }
        if (component.type === "cta") {
          return <CTA config={component.config as any} />;
        }
        if (component.type === "body") {
          return <Body config={component.config as BodyConfig} />;
        }
        if (component.type === "content") {
          return <Content config={component.config as any} primaryColor={site.primary_color} secondaryColor={site.secondary_color} />;
        }
        return null;
      })}

      {currentPage.slug === "proyectos" && (
        <ProjectList projects={projects} siteSlug={site.slug} layout={projectListLayout} />
      )}
    </>
  )}
</BaseLayout>
