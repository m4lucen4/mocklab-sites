---
import { getPublishedSites, getSitePages, getUserProjects } from "../../../lib/supabase";
import type { Site, SitePage, Project } from "../../../types";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectDetail from "../../../components/ProjectDetail.astro";

export async function getStaticPaths() {
  const sites = await getPublishedSites();

  const paths = await Promise.all(
    sites.map(async (site) => {
      const pages = await getSitePages(site.id);
      const projects = await getUserProjects(site.user_id);

      return projects.map((project) => ({
        params: { slug: site.slug, project: String(project.id) },
        props: { site, pages, project },
      }));
    })
  );

  return paths.flat();
}

interface Props {
  site: Site;
  pages: SitePage[];
  project: Project;
}

const { site, pages, project } = Astro.props;
---

<BaseLayout site={site} pages={pages} currentPageSlug="proyectos">
  <ProjectDetail project={project} siteSlug={site.slug} />
</BaseLayout>
