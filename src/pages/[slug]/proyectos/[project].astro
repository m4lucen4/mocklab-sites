---
import { getSiteBySlug, getSitePages, getProjectListComponent, getUserProjects } from "../../../lib/supabase";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectDetail from "../../../components/ProjectDetail.astro";
import type { ProjectListConfig } from "../../../types";

const { slug, project: projectId } = Astro.params;

const site = await getSiteBySlug(slug!);

if (!site) {
  return Astro.redirect('/404');
}

const [pages, projects, projectListComp] = await Promise.all([
  getSitePages(site.id),
  getUserProjects(site.user_id),
  getProjectListComponent(site.id),
]);

const project = projects.find((p) => String(p.id) === projectId);

if (!project) {
  return Astro.redirect('/404');
}

const detailType: 1 | 2 = ((projectListComp?.config as ProjectListConfig)?.detail_type ?? 1) as 1 | 2;
---

<BaseLayout site={site} pages={pages} currentPageSlug="proyectos">
  <ProjectDetail project={project} siteSlug={site.slug} detailType={detailType} fullWidth={!!site.full_width} />
</BaseLayout>
