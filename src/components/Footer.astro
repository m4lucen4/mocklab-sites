---
import type { Site } from "../types";

interface Props {
  site: Site;
  siteSlug: string;
}

const { site, siteSlug } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  data-component="footer"
  class="w-full border-t"
  style="background-color: var(--color-secondary); border-color: color-mix(in srgb, var(--color-primary) 15%, transparent);"
>
  <div class="max-w-7xl mx-auto px-6 md:px-16 py-4 md:py-0 md:h-16 flex flex-col md:flex-row md:items-center gap-3 md:gap-0 md:justify-between">

    <!-- Left: studio name / logo -->
    <a href={`/${siteSlug}/`} class="flex items-center" data-footer-logo-wrap>
      {site.logo_url ? (
        <img src={site.logo_url} alt={site.studio_name} class="h-8 w-auto" data-footer-logo />
      ) : (
        <span
          data-footer-studio
          class="text-sm font-semibold tracking-widest"
          style="color: var(--color-primary);"
        >
          {site.studio_name}
        </span>
      )}
    </a>

    <!-- Center: year -->
    <span
      data-footer-year
      class="text-sm opacity-60 md:absolute md:left-1/2 md:-translate-x-1/2"
      style="color: var(--color-primary);"
    >
      {currentYear}
    </span>

    <!-- Right: legal texts -->
    <div class="flex items-center gap-6">
      <span data-footer-legal="aviso-legal" class="text-sm opacity-60 cursor-pointer hover:opacity-100 transition-opacity" style="color: var(--color-primary);">Aviso Legal</span>
      <span data-footer-legal="politica-cookies" class="text-sm opacity-60 cursor-pointer hover:opacity-100 transition-opacity" style="color: var(--color-primary);">Política de Cookies</span>
    </div>

  </div>
</footer>
