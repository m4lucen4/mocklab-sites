---
import type { Site } from "../types";

interface Props {
  site: Site;
  siteSlug: string;
}

const { site, siteSlug } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  data-component="footer"
  class="border-t relative"
  style="width: 100vw; left: 50%; transform: translateX(-50%); background-color: var(--color-secondary); border-color: color-mix(in srgb, var(--color-primary) 15%, transparent);"
>
  <div class="px-6 md:px-16 py-4 md:py-0 md:h-16 flex flex-col md:flex-row md:items-center gap-3 md:gap-0 md:justify-between" style="max-width: 1400px; margin: 0 auto;">

    <!-- Left: studio name / logo -->
    <a href={`/${siteSlug}/`} class="flex items-center" data-footer-logo-wrap>
      {site.logo_url ? (
        <img src={site.logo_url} alt={site.studio_name} class="h-8 w-auto" data-footer-logo />
      ) : (
        <span
          data-footer-studio
          class="text-sm font-semibold tracking-widest"
          style="color: var(--color-primary);"
        >
          {site.studio_name}
        </span>
      )}
    </a>

    <!-- Center: year -->
    <span
      data-footer-year
      class="text-sm opacity-60 md:absolute md:left-1/2 md:-translate-x-1/2"
      style="color: var(--color-primary);"
    >
      {currentYear}
    </span>

    <!-- Right: legal texts -->
    <div class="flex items-center gap-6">
      <a href={`/${siteSlug}/aviso-legal`} data-footer-legal="aviso-legal" class="text-sm opacity-60 hover:opacity-100 transition-opacity" style="color: var(--color-primary);">Aviso Legal</a>
      <a href={`/${siteSlug}/politica-cookies`} data-footer-legal="politica-cookies" class="text-sm opacity-60 hover:opacity-100 transition-opacity" style="color: var(--color-primary);">Política de Cookies</a>
      <button data-cookie-settings type="button" class="text-sm opacity-60 hover:opacity-100 transition-opacity cursor-pointer bg-transparent border-none p-0" style="color: var(--color-primary);">Gestionar cookies</button>
    </div>

  </div>
</footer>
