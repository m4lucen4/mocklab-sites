---
import type { Project } from "../types";

interface Props {
  projects: Project[];
  siteSlug: string;
  layout?: "grid-4" | "grid-alternating";
  fullWidth?: boolean;
}

const { projects, siteSlug, layout = "grid-4", fullWidth = false } = Astro.props;

const groups: Project[][] = [];
if (layout === "grid-alternating") {
  for (let i = 0; i < projects.length; i += 3) {
    groups.push(projects.slice(i, i + 3));
  }
}

function truncate(text: string, maxWords = 20): string {
  const words = text.trim().split(/\s+/);
  return words.length <= maxWords ? text : words.slice(0, maxWords).join(" ") + "…";
}

const allCategories = Array.from(
  new Set(
    projects
      .map((p) => p.category)
      .filter(Boolean) as string[]
  )
);
---

<section data-preserve class="pt-24 pb-20 px-6 md:px-16">
  <div class={fullWidth ? "w-full" : "max-w-7xl mx-auto"}>

    <div class="flex items-start justify-between mb-10 gap-6">
      <h1 class="text-2xl md:text-4xl font-bold text-neutral-900 tracking-wide shrink-0" style="font-family: var(--title-font);">Projects</h1>

      <div class="flex flex-col items-end gap-3">
        <div class="flex items-center gap-4">
          <!-- View toggle -->
          <div class="flex items-center gap-1">
            <button id="btn-view-grid" class="p-1.5 text-neutral-900 transition-colors" aria-label="Grid view" title="Grid view">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
              </svg>
            </button>
            <button id="btn-view-list" class="p-1.5 text-neutral-400 transition-colors" aria-label="List view" title="List view">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
          </div>

          {allCategories.length > 0 && (
            <div class="relative">
              <select
                id="keyword-select"
                class="appearance-none pl-3 pr-8 py-1.5 text-xs font-semibold border border-neutral-900 bg-white text-neutral-900 cursor-pointer focus:outline-none"
                style="font-family: var(--font-family);"
              >
                <option value="">Filter by category</option>
                {allCategories.map((cat) => (
                  <option value={cat}>{cat}</option>
                ))}
              </select>
              <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-neutral-900">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </span>
            </div>
          )}
        </div>

        {allCategories.length > 0 && (
          <div id="active-pills" class="flex flex-wrap gap-2 justify-end min-h-[26px]"></div>
        )}
      </div>
    </div>

    <!-- Grid view (dashboard-configured) -->
    <div id="view-grid">
      {layout === "grid-4" && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {projects.map((project) => {
            const coverImage = project.image_data?.find((img) => img.url)?.url;
            return (
              <a
                href={`/${siteSlug}/proyectos/${project.id}`}
                class="project-card group block"
                data-category={project.category ?? ""}
              >
                <div class="aspect-3/4 overflow-hidden bg-neutral-100 mb-3">
                  {coverImage ? (
                    <img
                      src={coverImage}
                      alt={project.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : (
                    <div class="w-full h-full bg-[#e8e3d8]" />
                  )}
                </div>
                <p class="text-base font-bold text-neutral-900 mb-1" style="font-family: var(--title-font);">{project.title}</p>
                {project.description && (
                  <p class="text-sm text-neutral-700 mb-1 leading-relaxed" style="font-family: var(--font-family); font-weight: 400;">{truncate(project.description)}</p>
                )}
                {(project.category || project.year) && (
                  <p class="text-xs font-bold text-neutral-900" style="font-family: var(--font-family);">
                    {[project.category, project.year].filter(Boolean).join(" | ")}
                  </p>
                )}
              </a>
            );
          })}
        </div>
      )}

      {layout === "grid-alternating" && (
        <div class="flex flex-col gap-6">
          {groups.map((groupProjects, groupIndex) => {
            const isEvenGroup = groupIndex % 2 === 0;
            return (
              <div class:list={["alt-row", isEvenGroup ? "alt-row-even" : "alt-row-odd"]}>
                {groupProjects.map((project, posInGroup) => {
                  const coverImage = project.image_data?.find((img) => img.url)?.url;
                  const isLarge = isEvenGroup ? posInGroup === 2 : posInGroup === 0;
                  return (
                    <a
                      href={`/${siteSlug}/proyectos/${project.id}`}
                      class:list={["project-card group block", isLarge ? "alt-large" : ""]}
                      data-category={project.category ?? ""}
                      data-group={String(groupIndex)}
                      data-large={isLarge ? "" : undefined}
                    >
                      <div class:list={[
                        isLarge ? "aspect-[10/7] alt-img" : "aspect-[5/7] alt-img",
                        "overflow-hidden bg-neutral-100 mb-4"
                      ]}>
                        {coverImage ? (
                          <img
                            src={coverImage}
                            alt={project.title}
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                          />
                        ) : (
                          <div class="w-full h-full bg-[#e8e3d8]" />
                        )}
                      </div>
                      <p class="text-base font-bold text-neutral-900 mb-1" style="font-family: var(--title-font);">{project.title}</p>
                      {project.description && (
                        <p class="text-sm text-neutral-700 mb-1 leading-relaxed" style="font-family: var(--font-family); font-weight: 400;">
                          {truncate(project.description)}
                        </p>
                      )}
                      {(project.category || project.year) && (
                        <p class="text-xs font-bold text-neutral-900" style="font-family: var(--font-family);">
                          {[project.category, project.year].filter(Boolean).join(" | ")}
                        </p>
                      )}
                    </a>
                  );
                })}
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- List view (always available) -->
    <div id="view-list" class="hidden">
      <div class="divide-y divide-neutral-200">
        {projects.map((project) => {
          const coverImage = project.image_data?.find((img) => img.url)?.url;
          return (
            <a
              href={`/${siteSlug}/proyectos/${project.id}`}
              class="project-card group flex items-center gap-6 py-4 -mx-3 px-3 hover:bg-neutral-50 transition-colors"
              data-category={project.category ?? ""}
            >
              <div class="w-20 h-16 shrink-0 overflow-hidden bg-neutral-100">
                {coverImage ? (
                  <img
                    src={coverImage}
                    alt={project.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-[#e8e3d8]" />
                )}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-base font-bold text-neutral-900" style="font-family: var(--title-font);">{project.title}</p>
                {project.description && (
                  <p class="text-sm text-neutral-500 mt-0.5 truncate" style="font-family: var(--font-family);">{truncate(project.description, 15)}</p>
                )}
              </div>
              {(project.category || project.year) && (
                <p class="text-xs font-bold text-neutral-500 shrink-0" style="font-family: var(--font-family);">
                  {[project.category, project.year].filter(Boolean).join(" | ")}
                </p>
              )}
            </a>
          );
        })}
      </div>
    </div>

  </div>
</section>

<style>
  .project-card.hidden-by-filter {
    display: none;
  }
</style>

<style is:global>
  .alt-row {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .alt-row {
      grid-template-columns: 1fr 1fr;
    }
    .alt-row .alt-large {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .alt-row-even { grid-template-columns: 1fr 1fr 2fr; }
    .alt-row-odd  { grid-template-columns: 2fr 1fr 1fr; }
    .alt-row .alt-large { grid-column: auto; }
  }
</style>

<script>
  const select = document.getElementById("keyword-select") as HTMLSelectElement | null;
  const pillsContainer = document.getElementById("active-pills");
  const viewGrid = document.getElementById("view-grid")!;
  const viewList = document.getElementById("view-list")!;
  const btnGrid = document.getElementById("btn-view-grid")!;
  const btnList = document.getElementById("btn-view-list")!;

  const activeFilters = new Set<string>();
  let currentView: "grid" | "list" = "grid";

  // Capture all alt-grid cards once at init so we can rebuild rows after filtering
  const isAltGrid = viewGrid.querySelector(".project-card[data-group]") !== null;
  const allAltCards: HTMLElement[] = isAltGrid
    ? Array.from(viewGrid.querySelectorAll<HTMLElement>(".project-card[data-group]"))
    : [];

  // --- View toggle ---
  function setView(view: "grid" | "list") {
    currentView = view;
    if (view === "grid") {
      viewGrid.classList.remove("hidden");
      viewList.classList.add("hidden");
      btnGrid.classList.remove("text-neutral-400");
      btnGrid.classList.add("text-neutral-900");
      btnList.classList.remove("text-neutral-900");
      btnList.classList.add("text-neutral-400");
    } else {
      viewGrid.classList.add("hidden");
      viewList.classList.remove("hidden");
      btnList.classList.remove("text-neutral-400");
      btnList.classList.add("text-neutral-900");
      btnGrid.classList.remove("text-neutral-900");
      btnGrid.classList.add("text-neutral-400");
    }
  }

  btnGrid.addEventListener("click", () => setView("grid"));
  btnList.addEventListener("click", () => setView("list"));

  // --- Sync alternating grid image heights ---
  function syncAltHeights() {
    const groups = new Map<string, { smalls: HTMLElement[]; large: HTMLElement | null }>();
    viewGrid.querySelectorAll<HTMLElement>(".project-card[data-group]").forEach((card) => {
      const g = card.dataset.group!;
      if (!groups.has(g)) groups.set(g, { smalls: [], large: null });
      const entry = groups.get(g)!;
      const img = card.querySelector<HTMLElement>(".alt-img");
      if (!img) return;
      if ("large" in card.dataset) {
        entry.large = img;
      } else {
        entry.smalls.push(img);
      }
    });
    groups.forEach(({ smalls, large }) => {
      if (!large || smalls.length === 0) return;
      large.style.height = "";
    });
  }

  window.addEventListener("load", syncAltHeights);
  const ro = new ResizeObserver(syncAltHeights);
  ro.observe(viewGrid);

  // --- Rebuild alt-grid rows with only the visible cards ---
  function rebuildAltGrid() {
    const altContainer = viewGrid.querySelector<HTMLElement>(".flex.flex-col.gap-6");
    if (!altContainer) return;

    const visibleCards = activeFilters.size === 0
      ? allAltCards
      : allAltCards.filter((card) => activeFilters.has(card.dataset.category ?? ""));

    altContainer.innerHTML = "";

    for (let i = 0; i < visibleCards.length; i += 3) {
      const group = visibleCards.slice(i, i + 3);
      const groupIndex = Math.floor(i / 3);
      const isEven = groupIndex % 2 === 0;

      const row = document.createElement("div");
      row.className = `alt-row ${isEven ? "alt-row-even" : "alt-row-odd"}`;

      group.forEach((card, posInGroup) => {
        const isLarge = isEven ? posInGroup === 2 : posInGroup === 0;
        const imgEl = card.querySelector<HTMLElement>(".alt-img");

        if (imgEl) {
          imgEl.classList.toggle("aspect-[5/7]", !isLarge);
          imgEl.classList.toggle("aspect-[10/7]", isLarge);
        }

        card.classList.toggle("alt-large", isLarge);
        if (isLarge) {
          card.dataset.large = "";
        } else {
          delete card.dataset.large;
        }
        card.dataset.group = String(groupIndex);

        row.appendChild(card);
      });

      altContainer.appendChild(row);
    }
  }

  // --- Filter ---
  function applyFilters() {
    // List view always uses hidden-by-filter
    viewList.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
      if (activeFilters.size === 0) {
        card.classList.remove("hidden-by-filter");
      } else {
        card.classList.toggle("hidden-by-filter", !activeFilters.has(card.dataset.category ?? ""));
      }
    });

    // Alt-grid rebuilds rows; regular grid toggles visibility
    if (isAltGrid) {
      rebuildAltGrid();
    } else {
      viewGrid.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
        if (activeFilters.size === 0) {
          card.classList.remove("hidden-by-filter");
        } else {
          card.classList.toggle("hidden-by-filter", !activeFilters.has(card.dataset.category ?? ""));
        }
      });
    }
  }

  function addPill(category: string) {
    if (activeFilters.has(category)) return;
    activeFilters.add(category);

    const pill = document.createElement("span");
    pill.className = "inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold bg-neutral-900 text-white";
    pill.style.fontFamily = "var(--font-family)";
    pill.dataset.category = category;
    pill.innerHTML = `${category}<button class="ml-1 hover:opacity-70 transition-opacity" aria-label="Remove filter ${category}">✕</button>`;

    pill.querySelector("button")!.addEventListener("click", () => {
      activeFilters.delete(category);
      pill.remove();
      applyFilters();
    });

    pillsContainer?.appendChild(pill);
    applyFilters();
  }

  select?.addEventListener("change", () => {
    const value = select.value;
    if (value) {
      addPill(value);
      select.value = "";
    }
  });
</script>
