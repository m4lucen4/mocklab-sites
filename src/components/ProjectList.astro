---
import type { Project } from "../types";

interface Props {
  projects: Project[];
  siteSlug: string;
  layout?: "grid-4" | "grid-alternating";
}

const { projects, siteSlug, layout = "grid-4" } = Astro.props;

function truncate(text: string, maxWords = 20): string {
  const words = text.trim().split(/\s+/);
  return words.length <= maxWords ? text : words.slice(0, maxWords).join(" ") + "…";
}

const allKeywords = Array.from(
  new Set(
    projects
      .map((p) => p.keywords)
      .filter(Boolean)
      .flatMap((k) => k.split(",").map((kw) => kw.trim()))
      .filter(Boolean)
  )
);


---

<section data-preserve class="pt-24 pb-20 px-6 md:px-16">
  <div class="max-w-7xl mx-auto">

    <div class="flex items-start justify-between mb-10 gap-6">
      <h1 class="text-4xl font-bold text-neutral-900 tracking-wide shrink-0" style="font-family: var(--title-font);">Proyectos</h1>

      {allKeywords.length > 0 && (
        <div class="flex flex-col items-end gap-3">
          <!-- Select -->
          <div class="relative">
            <select
              id="keyword-select"
              class="appearance-none pl-3 pr-8 py-1.5 text-xs font-semibold border border-neutral-900 bg-white text-neutral-900 cursor-pointer focus:outline-none"
              style="font-family: var(--font-family);"
            >
              <option value="">Filtrar por categoría</option>
              {allKeywords.map((kw) => (
                <option value={kw}>{kw}</option>
              ))}
            </select>
            <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-neutral-900">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </span>
          </div>
          <!-- Active pills -->
          <div id="active-pills" class="flex flex-wrap gap-2 justify-end"></div>
        </div>
      )}
    </div>

    <!-- Grid-4 layout -->
    {layout === "grid-4" && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" id="projects-grid">
        {projects.map((project) => {
          const coverImage = project.image_data?.find((img) => img.url)?.url;
          const keywords = project.keywords?.split(",").map((k) => k.trim()).filter(Boolean) ?? [];
          return (
            <a
              href={`/${siteSlug}/proyectos/${project.id}`}
              class="project-card group block"
              data-keywords={keywords.join(",")}
            >
              <div class="aspect-3/4 overflow-hidden bg-neutral-100 mb-3">
                {coverImage ? (
                  <img
                    src={coverImage}
                    alt={project.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-[#e8e3d8]" />
                )}
              </div>
              <p class="text-sm font-bold text-neutral-900 mb-1" style="font-family: var(--title-font);">{project.title}</p>
              {project.description && (
                <p class="text-xs text-neutral-700 mb-1 leading-relaxed" style="font-family: var(--font-family); font-weight: 400;">{truncate(project.description)}</p>
              )}
              {(project.category || project.year) && (
                <p class="text-[0.65rem] font-bold text-neutral-900" style="font-family: var(--font-family);">
                  {[project.category, project.year].filter(Boolean).join(" | ")}
                </p>
              )}
            </a>
          );
        })}
      </div>
    )}

    <!-- Grid-alternating layout -->
    {layout === "grid-alternating" && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6" id="projects-grid">
        {projects.map((project, index) => {
          const coverImage = project.image_data?.find((img) => img.url)?.url;
          const groupIndex = Math.floor(index / 3);
          const posInGroup = index % 3;
          const isEvenGroup = groupIndex % 2 === 0;
          const isLarge = isEvenGroup ? posInGroup === 2 : posInGroup === 0;
          const span = isLarge ? "md:col-span-2 lg:col-span-6" : "md:col-span-1 lg:col-span-3";
          const keywords = project.keywords?.split(",").map((k) => k.trim()).filter(Boolean) ?? [];
          return (
            <a
              href={`/${siteSlug}/proyectos/${project.id}`}
              class:list={["project-card group block", span]}
              data-keywords={keywords.join(",")}
            >
              <div class:list={[
                isLarge ? "aspect-3/2" : "aspect-[5/7]",
                "overflow-hidden bg-neutral-100 mb-4"
              ]}>
                {coverImage ? (
                  <img
                    src={coverImage}
                    alt={project.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-[#e8e3d8]" />
                )}
              </div>
              <p class="text-sm font-bold text-neutral-900 mb-1" style="font-family: var(--title-font);">{project.title}</p>
              {project.description && (
                <p class="text-xs text-neutral-700 mb-1 leading-relaxed" style="font-family: var(--font-family); font-weight: 400;">
                  {truncate(project.description)}
                </p>
              )}
              {(project.category || project.year) && (
                <p class="text-[0.65rem] font-bold text-neutral-900" style="font-family: var(--font-family);">
                  {[project.category, project.year].filter(Boolean).join(" | ")}
                </p>
              )}
            </a>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .project-card.hidden-by-filter {
    display: none;
  }
</style>

<script>
  const select = document.getElementById("keyword-select") as HTMLSelectElement | null;
  const pillsContainer = document.getElementById("active-pills");
  const projectCards = document.querySelectorAll<HTMLElement>(".project-card");

  const activeFilters = new Set<string>();

  function applyFilters() {
    projectCards.forEach((card) => {
      if (activeFilters.size === 0) {
        card.classList.remove("hidden-by-filter");
        return;
      }
      const cardKeywords = (card.dataset.keywords ?? "").split(",").map((k) => k.trim());
      const matches = [...activeFilters].some((f) => cardKeywords.includes(f));
      card.classList.toggle("hidden-by-filter", !matches);
    });
  }

  function addPill(keyword: string) {
    if (activeFilters.has(keyword)) return;
    activeFilters.add(keyword);

    const pill = document.createElement("span");
    pill.className = "inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold bg-neutral-900 text-white";
    pill.style.fontFamily = "var(--font-family)";
    pill.dataset.keyword = keyword;
    pill.innerHTML = `${keyword}<button class="ml-1 hover:opacity-70 transition-opacity" aria-label="Eliminar filtro ${keyword}">✕</button>`;

    pill.querySelector("button")!.addEventListener("click", () => {
      activeFilters.delete(keyword);
      pill.remove();
      applyFilters();
    });

    pillsContainer?.appendChild(pill);
    applyFilters();
  }

  select?.addEventListener("change", () => {
    const value = select.value;
    if (value) {
      addPill(value);
      select.value = "";
    }
  });
</script>
