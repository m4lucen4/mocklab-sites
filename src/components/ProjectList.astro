---
import type { Project } from "../types";

interface Props {
  projects: Project[];
  siteSlug: string;
  layout?: "grid-4" | "grid-alternating";
}

const { projects, siteSlug, layout = "grid-4" } = Astro.props;

// Extract unique keywords for filter buttons
const allKeywords = Array.from(
  new Set(
    projects
      .map((p) => p.keywords)
      .filter(Boolean)
      .flatMap((k) => k.split(",").map((kw) => kw.trim()))
      .filter(Boolean)
  )
);

// Helper: get col-span class for alternating layout
function getAlternatingSpan(index: number): string {
  const groupIndex = Math.floor(index / 3);
  const posInGroup = index % 3;
  const isEvenGroup = groupIndex % 2 === 0;

  if (isEvenGroup) {
    // Pattern: small, small, large (1/4, 1/4, 1/2)
    return posInGroup === 2 ? "col-span-6" : "col-span-3";
  } else {
    // Pattern: large, small, small (1/2, 1/4, 1/4)
    return posInGroup === 0 ? "col-span-6" : "col-span-3";
  }
}
---

<section data-preserve class="pt-24 pb-20 px-6 md:px-16">
  <div class="max-w-7xl mx-auto">

    <!-- Header: title + filter buttons -->
    <div class="flex items-center justify-between mb-10 gap-6">
      <h1 class="text-2xl font-light text-neutral-900 tracking-wide">Portfolio</h1>

      {allKeywords.length > 0 && (
        <div class="flex items-center gap-3 flex-wrap justify-end" id="filter-buttons">
          {allKeywords.map((kw) => (
            <button
              class="filter-btn px-3 py-1.5 text-xs font-semibold bg-black text-white border border-black hover:bg-white hover:text-black transition-colors"
              data-filter={kw}
            >
              {kw}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Grid-4 layout -->
    {layout === "grid-4" && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" id="projects-grid">
        {projects.map((project) => {
          const coverImage = project.image_data?.find((img) => img.url)?.url;
          const keywords = project.keywords?.split(",").map((k) => k.trim()).filter(Boolean) ?? [];
          return (
            <a
              href={`/${siteSlug}/proyectos/${project.id}`}
              class="project-card group block"
              data-keywords={keywords.join(",")}
            >
              <div class="aspect-3/4 overflow-hidden bg-neutral-100 mb-3">
                {coverImage ? (
                  <img
                    src={coverImage}
                    alt={project.titulo}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-[#e8e3d8]" />
                )}
              </div>
              <p class="text-sm text-neutral-900 mb-1">{project.titulo}</p>
              <p class="text-xs font-bold text-neutral-900">
                {[project.keywords, project.year].filter(Boolean).join(" | ")}
              </p>
            </a>
          );
        })}
      </div>
    )}

    <!-- Grid-alternating layout -->
    {layout === "grid-alternating" && (
      <div class="grid grid-cols-12 gap-6" id="projects-grid">
        {projects.map((project, index) => {
          const coverImage = project.image_data?.find((img) => img.url)?.url;
          const span = getAlternatingSpan(index);
          const keywords = project.keywords?.split(",").map((k) => k.trim()).filter(Boolean) ?? [];
          return (
            <a
              href={`/${siteSlug}/proyectos/${project.id}`}
              class:list={["project-card group block", span]}
              data-keywords={keywords.join(",")}
            >
              <div class="aspect-3/4 overflow-hidden bg-neutral-100 mb-4">
                {coverImage ? (
                  <img
                    src={coverImage}
                    alt={project.titulo}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-[#e8e3d8]" />
                )}
              </div>
              <p class="text-sm text-neutral-900 mb-2">{project.titulo}</p>
              {project.descripcion && (
                <p class="text-xs text-neutral-500 mb-3 leading-relaxed line-clamp-4">
                  {project.descripcion}
                </p>
              )}
              <p class="text-xs font-bold text-neutral-900">
                {[project.keywords, project.year].filter(Boolean).join(" | ")}
              </p>
            </a>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .project-card.hidden-by-filter {
    display: none;
  }
  .filter-btn.active {
    background-color: white;
    color: black;
  }
  .filter-btn.active:hover {
    background-color: black;
    color: white;
  }
</style>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const projectCards = document.querySelectorAll<HTMLElement>(".project-card");

  let activeFilter: string | null = null;

  filterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter ?? null;

      if (activeFilter === filter) {
        // Deselect
        activeFilter = null;
        filterButtons.forEach((b) => b.classList.remove("active"));
        projectCards.forEach((card) => card.classList.remove("hidden-by-filter"));
        return;
      }

      activeFilter = filter;
      filterButtons.forEach((b) => {
        b.classList.toggle("active", b.dataset.filter === filter);
      });

      projectCards.forEach((card) => {
        const cardKeywords = (card.dataset.keywords ?? "")
          .split(",")
          .map((k) => k.trim());
        const matches = filter ? cardKeywords.includes(filter) : true;
        card.classList.toggle("hidden-by-filter", !matches);
      });
    });
  });
</script>
