---
import type { RichTextConfig } from "../types";

interface Props {
  config: RichTextConfig;
}

const { config } = Astro.props;

const widthClass = {
  full: "w-full",
  "two-thirds": "w-full md:w-2/3",
  half: "w-full md:w-1/2",
}[config.width ?? "full"];

const alignClass =
  (config.width ?? "full") === "full"
    ? ""
    : config.alignment === "right"
      ? "ml-auto"
      : "mr-auto";
---

<section
  data-component="rich_text"
  class="px-6 md:px-16 py-8"
  style={`color: var(--color-primary);`}
>
  <div
    class={`html-content text-base leading-relaxed ${widthClass} ${alignClass}`}
    style={`text-align: ${config.alignment};`}
    set:html={config.content}
  />
</section>
