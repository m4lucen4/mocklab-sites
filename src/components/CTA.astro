---
interface CTAConfig {
  title: string;
  description: string;
  type: 1 | 2 | 3;
  subtitle?: string;
  // Type 1 buttons (optional)
  text_primary_button?: string;
  url_primary_button?: string;
  text_secondary_button?: string;
  url_secondary_button?: string;
}

interface Props {
  config: CTAConfig;
}

const { config } = Astro.props;
const {
  title,
  description,
  type,
  text_primary_button,
  url_primary_button,
  text_secondary_button,
  url_secondary_button,
  subtitle,
} = config;

function linkProps(url: string) {
  return url?.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {};
}
---

{type === 1 && (
  <section
    data-component="cta"
    class="flex items-center justify-center w-full bg-white"
    style="min-height: 500px;"
  >
    <div class="text-center px-6 py-16 max-w-3xl mx-auto">
      {subtitle && <p class="text-sm font-medium text-gray-200 mb-3 tracking-wide">{subtitle}</p>}
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-primary); font-family: var(--title-font);">{title}</h2>
      <p class="text-lg mb-8" style="color: var(--color-primary); opacity: 0.75;">{description}</p>
      {(text_primary_button || text_secondary_button) && (
        <div class="flex items-center justify-center gap-4 flex-wrap">
          {text_primary_button && url_primary_button && (
            <a
              href={url_primary_button}
              {...linkProps(url_primary_button)}
              class="inline-block px-8 py-3 font-semibold text-white rounded"
              style="background-color: var(--color-primary);"
            >
              {text_primary_button}
            </a>
          )}
          {text_secondary_button && url_secondary_button && (
            <a
              href={url_secondary_button}
              {...linkProps(url_secondary_button)}
              class="inline-flex items-center gap-2 font-semibold"
              style="color: var(--color-primary);"
            >
              {text_secondary_button}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}

{type === 3 && (
  <section
    data-component="cta"
    class="flex items-center w-full bg-white"
    style="min-height: 500px;"
  >
    <div class="px-6 md:px-16 py-16 max-w-2xl">
      {subtitle && <p class="text-sm font-medium text-gray-400 mb-3 tracking-wide">{subtitle}</p>}
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-primary); font-family: var(--title-font);">{title}</h2>
      <p class="text-lg mb-8" style="color: var(--color-primary); opacity: 0.75;">{description}</p>
      {(text_primary_button || text_secondary_button) && (
        <div class="flex items-center gap-4 flex-wrap">
          {text_primary_button && url_primary_button && (
            <a
              href={url_primary_button}
              {...linkProps(url_primary_button)}
              class="inline-block px-8 py-3 font-semibold text-white rounded"
              style="background-color: var(--color-primary);"
            >
              {text_primary_button}
            </a>
          )}
          {text_secondary_button && url_secondary_button && (
            <a
              href={url_secondary_button}
              {...linkProps(url_secondary_button)}
              class="inline-flex items-center gap-2 font-semibold"
              style="color: var(--color-primary);"
            >
              {text_secondary_button}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}

{type === 2 && (
  <section
    data-component="cta"
    class="flex flex-col md:flex-row w-full"
    style="min-height: 400px;"
  >
    <div class="w-full md:w-1/2" style="min-height: 300px; background-color: var(--color-secondary);"></div>
    <div class="flex flex-col justify-center px-10 py-12 w-full md:w-1/2 bg-white">
      {subtitle && <p class="text-sm font-medium text-gray-400 mb-3 tracking-wide">{subtitle}</p>}
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-primary); font-family: var(--title-font);">{title}</h2>
      <p class="text-base mb-8" style="color: var(--color-primary); opacity: 0.75;">{description}</p>
      {text_primary_button && url_primary_button && (
        <a
          href={url_primary_button}
          {...linkProps(url_primary_button)}
          class="inline-block self-start px-8 py-3 font-semibold text-white rounded"
          style="background-color: var(--color-primary);"
        >
          {text_primary_button}
        </a>
      )}
    </div>
  </section>
)}
