---
import type { BodyConfig } from "../types";

interface Props {
  config: BodyConfig;
}

const { config } = Astro.props;
const { description, image_1, image_2, image_3, type } = config;

const imgStyle = "width: 100%; height: 100%; object-fit: cover; display: block;";
const descStyle = "align-self: end; padding: 2rem 2.5rem; color: var(--color-primary);";
---


{type === 1 && (
  <section data-component="body" class="body-grid body-grid-1">
    <div class="img-wrapper">{image_1 && <img src={image_1} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper">{image_2 && <img src={image_2} alt="" style={imgStyle} />}</div>
    <div style={descStyle}><div class="html-content" style="margin: 0; line-height: 1.6;" set:html={description} /></div>
  </section>
)}

{type === 2 && (
  <section data-component="body" class="body-grid body-grid-2">
    <div class="img-wrapper-wide">{image_1 && <img src={image_1} alt="" style={imgStyle} />}</div>
    <div style={descStyle}><div class="html-content" style="margin: 0; line-height: 1.6;" set:html={description} /></div>
  </section>
)}

{type === 3 && (
  <section data-component="body" class="body-grid body-grid-3">
    <div class="img-wrapper">{image_1 && <img src={image_1} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper">{image_2 && <img src={image_2} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper">{image_3 && <img src={image_3} alt="" style={imgStyle} />}</div>
    <div style={descStyle}><div class="html-content" style="margin: 0; line-height: 1.6;" set:html={description} /></div>
  </section>
)}

{type === 4 && (
  <section data-component="body" class="body-grid body-grid-4">
    <div class="img-wrapper">{image_1 && <img src={image_1} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper">{image_2 && <img src={image_2} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper-wide">{image_3 && <img src={image_3} alt="" style={imgStyle} />}</div>
  </section>
)}

{type === 5 && (
  <section data-component="body" class="body-grid body-grid-5">
    <div class="img-wrapper">{image_1 && <img src={image_1} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper">{image_2 && <img src={image_2} alt="" style={imgStyle} />}</div>
    <div class="img-wrapper">{image_3 && <img src={image_3} alt="" style={imgStyle} />}</div>
  </section>
)}
