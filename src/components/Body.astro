---
import type { BodyConfig } from "../types";

interface Props {
  config: BodyConfig;
}

const { config } = Astro.props;
const { description, image_1, image_2, image_3, type } = config;

// aspect-ratio on the wrapper + 100%/100% on the img ensures 4/3 is respected
// align-self: start prevents the grid from stretching image cells to row height
const imgWrapperStyle = "aspect-ratio: 2/3; overflow: hidden; align-self: start;";
const imgWrapperStyleWide = "aspect-ratio: 4/3; overflow: hidden; align-self: start;";
const imgStyle = "width: 100%; height: 100%; object-fit: cover; display: block;";
// align-self: center vertically centers the description within the grid row
const descStyle = "align-self: end; padding: 2rem 2.5rem; color: var(--color-primary);";

const gridCols: Record<number, string> = {
  1: "1fr 1fr 1fr",
  2: "1fr 1fr",
  3: "1fr 1fr 1fr 1fr",
  4: "1fr 1fr 2fr",
};
---

{type === 1 && (
  <section
    data-component="body"
    style={`display: grid; grid-template-columns: ${gridCols[1]}; gap: 8px;`}
  >
    {image_1 && <div style={imgWrapperStyle}><img src={image_1} alt="" style={imgStyle} /></div>}
    {image_2 && <div style={imgWrapperStyle}><img src={image_2} alt="" style={imgStyle} /></div>}
    <div style={descStyle}><p style="margin: 0; line-height: 1.6;">{description}</p></div>
  </section>
)}

{type === 2 && (
  <section
    data-component="body"
    style={`display: grid; grid-template-columns: ${gridCols[2]}; gap: 8px;`}
  >
    {image_1 && <div style={imgWrapperStyleWide}><img src={image_1} alt="" style={imgStyle} /></div>}
    <div style={descStyle}><p style="margin: 0; line-height: 1.6;">{description}</p></div>
  </section>
)}

{type === 3 && (
  <section
    data-component="body"
    style={`display: grid; grid-template-columns: ${gridCols[3]}; gap: 8px;`}
  >
    {image_1 && <div style={imgWrapperStyle}><img src={image_1} alt="" style={imgStyle} /></div>}
    {image_2 && <div style={imgWrapperStyle}><img src={image_2} alt="" style={imgStyle} /></div>}
    {image_3 && <div style={imgWrapperStyle}><img src={image_3} alt="" style={imgStyle} /></div>}
    <div style={descStyle}><p style="margin: 0; line-height: 1.6;">{description}</p></div>
  </section>
)}

{type === 4 && (
  <section
    data-component="body"
    style={`display: grid; grid-template-columns: ${gridCols[4]}; gap: 8px;`}
  >
    {image_1 && <div style={imgWrapperStyle}><img src={image_1} alt="" style={imgStyle} /></div>}
    {image_2 && <div style={imgWrapperStyle}><img src={image_2} alt="" style={imgStyle} /></div>}
    {image_3 && <div style={imgWrapperStyleWide}><img src={image_3} alt="" style={imgStyle} /></div>}
  </section>
)}
