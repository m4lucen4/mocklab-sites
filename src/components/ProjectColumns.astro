---
import type { ProjectColumnsConfig, Project } from "../types";

interface Props {
  config: ProjectColumnsConfig;
  projects: Project[];
  siteSlug: string;
}

const { config, projects, siteSlug } = Astro.props;
const {
  columns,
  project_1,
  project_2,
  vertical_align_1 = "top",
  vertical_align_2 = "top",
  horizontal_align = "between",
} = config;

const p1 = project_1 ? projects.find((p) => String(p.id) === String(project_1)) : undefined;
const p2 = project_2 ? projects.find((p) => String(p.id) === String(project_2)) : undefined;

const vMap: Record<string, string> = { top: "justify-start", center: "justify-center", bottom: "justify-end" };
const hMap: Record<string, string> = { start: "justify-start", end: "justify-end", between: "justify-between" };

const v1Class = vMap[vertical_align_1] ?? "justify-start";
const v2Class = vMap[vertical_align_2] ?? "justify-start";
const isStretch = horizontal_align === "stretch";
const hClass = hMap[horizontal_align] ?? "justify-between";

const sectionPadding = isStretch ? "2rem 8rem" : "2rem 2.5rem";
const colStyle = isStretch ? "flex: 1; min-width: 0;" : "width: 40%; flex: none;";
const gapClass = isStretch ? "gap-16" : "gap-8";

const imgStyle = "width: 100%; height: auto; display: block;";
const placeholderStyle = "width: 100%; aspect-ratio: 4/3; background-color: #e5e7eb; display: block;";

const pcProjects = JSON.stringify([
  p1 ? { id: p1.id, title: p1.title, category: p1.category ?? null, year: p1.year, image_url: p1.image_data?.[0]?.url ?? null } : null,
  p2 ? { id: p2.id, title: p2.title, category: p2.category ?? null, year: p2.year, image_url: p2.image_data?.[0]?.url ?? null } : null,
]);
---

{columns === 1 && p1 && (
  <section data-component="project_columns" data-projects={pcProjects} style="padding: 2rem 2.5rem;">
    <div style="max-width: 42rem; margin: 0 auto;">
      <a href={`/${siteSlug}/proyectos/${p1.id}`} class={`group flex flex-col ${v1Class}`} style="text-decoration: none; color: inherit;">
        <div style="overflow: hidden;">
          {p1.image_data?.[0]?.url
            ? <img src={p1.image_data[0].url} alt={p1.title} class="transition-transform duration-500 group-hover:scale-105" style={imgStyle} />
            : <div style={placeholderStyle} />
          }
        </div>
        <div style="margin-top: 0.75rem;">
          <p style="margin: 0; font-size: 1rem; font-weight: 600; color: var(--color-primary);">{p1.title}</p>
          {(p1.category || p1.year) && (
            <p style="margin: 0.25rem 0 0; font-size: 0.875rem; color: var(--color-primary); opacity: 0.65;">
              {[p1.category, p1.year].filter(Boolean).join(" · ")}
            </p>
          )}
        </div>
      </a>
    </div>
  </section>
)}

{columns === 2 && (p1 || p2) && (
  <section data-component="project_columns" data-projects={pcProjects} style={`padding: ${sectionPadding};`}>
    <div class={`flex ${gapClass} ${isStretch ? "" : hClass}`}>
      {p1 && (
        <a href={`/${siteSlug}/proyectos/${p1.id}`} class={`group flex flex-col ${v1Class}`} style={`${colStyle} text-decoration: none; color: inherit;`}>
          <div style="overflow: hidden;">
            {p1.image_data?.[0]?.url
              ? <img src={p1.image_data[0].url} alt={p1.title} class="transition-transform duration-500 group-hover:scale-105" style={imgStyle} />
              : <div style={placeholderStyle} />
            }
          </div>
          <div style="margin-top: 0.75rem;">
            <p style="margin: 0; font-size: 1rem; font-weight: 600; color: var(--color-primary);">{p1.title}</p>
            {(p1.category || p1.year) && (
              <p style="margin: 0.25rem 0 0; font-size: 0.875rem; color: var(--color-primary); opacity: 0.65;">
                {[p1.category, p1.year].filter(Boolean).join(" · ")}
              </p>
            )}
          </div>
        </a>
      )}
      {p2 && (
        <a href={`/${siteSlug}/proyectos/${p2.id}`} class={`group flex flex-col ${v2Class}`} style={`${colStyle} text-decoration: none; color: inherit;`}>
          <div style="overflow: hidden;">
            {p2.image_data?.[0]?.url
              ? <img src={p2.image_data[0].url} alt={p2.title} class="transition-transform duration-500 group-hover:scale-105" style={imgStyle} />
              : <div style={placeholderStyle} />
            }
          </div>
          <div style="margin-top: 0.75rem;">
            <p style="margin: 0; font-size: 1rem; font-weight: 600; color: var(--color-primary);">{p2.title}</p>
            {(p2.category || p2.year) && (
              <p style="margin: 0.25rem 0 0; font-size: 0.875rem; color: var(--color-primary); opacity: 0.65;">
                {[p2.category, p2.year].filter(Boolean).join(" · ")}
              </p>
            )}
          </div>
        </a>
      )}
    </div>
  </section>
)}
