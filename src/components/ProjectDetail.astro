---
import type { Project } from "../types";

interface Props {
  project: Project;
  siteSlug: string;
}

const { project, siteSlug } = Astro.props;
const images = (project.image_data || []).filter((img) => img.url);
---

<article class="pt-24 pb-16 px-6 md:px-16">
  <div class="max-w-5xl mx-auto">
    <a
      href={`/${siteSlug}/proyectos`}
      class="inline-flex items-center gap-2 text-sm text-neutral-500 hover:text-[var(--color-primary)] transition-colors mb-8"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      Volver a proyectos
    </a>

    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-wide uppercase mb-4" style="font-family: var(--title-font);">
        {project.titulo}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500 mb-6">
        {project.year && <span>{project.year}</span>}
        {project.keywords && (
          <span class="before:content-['·'] before:mr-4">{project.keywords}</span>
        )}
      </div>
      {project.descripcion && (
        <p class="text-base text-neutral-700 leading-relaxed max-w-3xl">
          {project.descripcion}
        </p>
      )}
    </header>

    {images.length > 0 && (
      <div class="grid grid-cols-1 gap-4">
        {images.map((img, i) => (
          <div class="overflow-hidden">
            <img
              src={img.url}
              alt={`${project.titulo} - Imagen ${i + 1}`}
              class="w-full h-auto object-cover"
            />
          </div>
        ))}
      </div>
    )}
  </div>
</article>
