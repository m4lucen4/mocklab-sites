---
import type { Project } from "../types";

interface Props {
  project: Project;
  siteSlug: string;
  detailType?: 1 | 2;
  fullWidth?: boolean;
}

const { project, siteSlug, detailType = 1, fullWidth = false } = Astro.props;
const wrapClass = "max-w-[1600px] mx-auto";
const collaborators = project.projectCollaborators ?? [];
const collaboratorGroups = collaborators.reduce<{ profession: string; names: string[] }[]>((acc, c) => {
  const existing = acc.find((g) => g.profession === c.profession);
  if (existing) { existing.names.push(c.name); } else { acc.push({ profession: c.profession, names: [c.name] }); }
  return acc;
}, []);
const images = (project.image_data || []).filter((img) => img.url);
const heroImage = images[0];
const galleryImages = images.slice(1);
const keywords = project.keywords?.split(",").map((k) => k.trim()).filter(Boolean) ?? [];

// Type 2: split description into paragraphs and build alternating image sections
// Even sections → "pair" block (2/3 + 1/3, consumes 2 images)
// Odd sections  → "solo" block (centered 1/2 width, consumes 1 image)
type ImgItem = (typeof galleryImages)[0];
type Section =
  | { kind: "pair"; para: string | null; img1: ImgItem | null; img2: ImgItem | null }
  | { kind: "solo"; para: string | null; img: ImgItem | null };

const descParagraphs = (project.description ?? "")
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

const descriptionHtml = project.description
  ? project.description
      .split(/\n\n+/)
      .map((p) => `<p>${p.trim().replace(/\n/g, "<br>")}</p>`)
      .join("")
  : "";
const remainingImages = galleryImages.slice(2);

const sections: Section[] = [];
let imgIdx = 0;
let paraIdx = 0;
while (imgIdx < remainingImages.length || paraIdx < descParagraphs.length) {
  const para = descParagraphs[paraIdx] ?? null;
  paraIdx++;
  if (sections.length % 2 === 0) {
    const img1 = remainingImages[imgIdx] ?? null; imgIdx++;
    const img2 = remainingImages[imgIdx] ?? null; imgIdx++;
    sections.push({ kind: "pair", para, img1, img2 });
  } else {
    const img = remainingImages[imgIdx] ?? null; imgIdx++;
    sections.push({ kind: "solo", para, img });
  }
}

type GalleryRow =
  | { type: "solo"; img: (typeof galleryImages)[0] }
  | { type: "multi"; imgs: typeof galleryImages };

const galleryRows: GalleryRow[] = [];
if (galleryImages.length > 0) {
  galleryRows.push({ type: "solo", img: galleryImages[0] });
  if (galleryImages.length > 1) {
    galleryRows.push({ type: "multi", imgs: galleryImages.slice(1) });
  }
}
---

{detailType === 2 ? (

  <article data-preserve class="pt-16">

    <!-- Title + year -->
    <div class="px-6 md:px-12 lg:px-20 pt-12 pb-14">
      <div class={wrapClass}>
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-none uppercase mb-4"
          style="font-family: var(--title-font);"
        >
          {project.title}
        </h1>
        {project.year && (
          <span class="text-sm tracking-[0.2em] uppercase text-neutral-500" style="font-family: var(--font-family);">{project.year}</span>
        )}
      </div>
    </div>

    <!-- Hero image -->
    {heroImage ? (
      <div class="px-6 md:px-12 lg:px-20">
        <div class={`${wrapClass} overflow-hidden bg-neutral-100`} style="height: 92vh;">
          <img
            src={heroImage.url}
            alt={project.title}
            class="w-full h-full object-cover"
            data-lightbox
            data-lightbox-group="project-gallery"
            style="cursor:zoom-in;"
          />
        </div>
      </div>
    ) : null}

    <!-- Collaborators -->
    {collaborators.length > 0 && (
      <div class="px-6 md:px-12 lg:px-20 py-10">
        <div class={`${wrapClass} grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 items-baseline`}>
          {collaboratorGroups.map((g) => (
            <>
              <span
                class="text-xs tracking-[0.2em] uppercase text-neutral-400"
                style="font-family: var(--font-family);"
              >
                {g.profession}
              </span>
              <span
                class="text-sm text-neutral-700"
                style="font-family: var(--font-family);"
              >
                {g.names.join(" · ")}
              </span>
            </>
          ))}
        </div>
      </div>
    )}

    <!-- First two gallery images: 1/3 + 2/3 -->
    {galleryImages.length >= 1 && (
      <div class="px-6 md:px-12 lg:px-20 py-10">
        <div class={`${wrapClass} grid grid-cols-1 md:grid-cols-3 gap-4 md:h-[72vh]`}>
          <div class="overflow-hidden bg-neutral-100 aspect-4/3 md:aspect-auto">
            <img
              src={galleryImages[0].url}
              alt={project.title}
              class="w-full h-full object-cover"
              data-lightbox
              data-lightbox-group="project-gallery"
              style="cursor:zoom-in;"
            />
          </div>
          {galleryImages[1] && (
            <div class="overflow-hidden bg-neutral-100 aspect-4/3 md:aspect-auto md:col-span-2">
              <img
                src={galleryImages[1].url}
                alt={project.title}
                class="w-full h-full object-cover"
                data-lightbox
                data-lightbox-group="project-gallery"
                style="cursor:zoom-in;"
              />
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Alternating image sections -->
    {sections.length > 0 && (
      <div class="px-6 md:px-12 lg:px-20 pb-28">
        <div class={`${wrapClass} flex flex-col gap-20`}>
          {sections.map((section) => (
            <div class="flex flex-col gap-10">

              {section.para && (
                <p
                  class="text-lg text-neutral-600 leading-tight w-full md:w-1/2"
                  style="font-family: var(--font-family);"
                >
                  {section.para}
                </p>
              )}

              {section.kind === "pair" && (section.img1 || section.img2) && (
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:h-[72vh]">
                  {section.img1 && (
                    <div class="overflow-hidden bg-neutral-100 aspect-4/3 md:aspect-auto md:col-span-2">
                      <img src={section.img1.url} alt={project.title} class="w-full h-full object-cover" data-lightbox data-lightbox-group="project-gallery" style="cursor:zoom-in;" />
                    </div>
                  )}
                  {section.img2 && (
                    <div class="overflow-hidden bg-neutral-100 aspect-4/3 md:aspect-auto">
                      <img src={section.img2.url} alt={project.title} class="w-full h-full object-cover" data-lightbox data-lightbox-group="project-gallery" style="cursor:zoom-in;" />
                    </div>
                  )}
                </div>
              )}

              {section.kind === "solo" && section.img && (
                <div class="grid grid-cols-1 md:grid-cols-5">
                  <div class="md:col-start-2 md:col-span-3 overflow-hidden bg-neutral-100 aspect-3/2 md:aspect-auto md:h-[72vh]">
                    <img src={section.img.url} alt={project.title} class="w-full h-full object-cover" data-lightbox data-lightbox-group="project-gallery" style="cursor:zoom-in;" />
                  </div>
                </div>
              )}

            </div>
          ))}
        </div>
      </div>
    )}

  </article>

) : (

  <article data-preserve>

    <!-- Hero image -->
    {heroImage ? (
      <div class="relative w-full overflow-hidden bg-neutral-100" style="height: 92vh;">
        <img
          src={heroImage.url}
          alt={project.title}
          class="w-full h-full object-cover"
          data-lightbox
          data-lightbox-group="project-gallery"
          style="cursor:zoom-in;"
        />
        <div class="absolute inset-0 bg-black/10 pointer-events-none"></div>
      </div>
    ) : (
      <div class="w-full bg-neutral-100" style="height: 40vh;"></div>
    )}

    <!-- Project info -->
    <div class="px-6 md:px-12 lg:px-20 mt-14">
      <div class={wrapClass}>

        <!-- Title + meta -->
        <div class="pb-10">
          <h1
            class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] uppercase mb-6"
            style="font-family: var(--title-font);"
          >
            {project.title}
          </h1>

          <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
            {project.year && (
              <span class="text-xs tracking-[0.2em] uppercase text-neutral-500" style="font-family: var(--font-family);">{project.year}</span>
            )}
            {project.category && (
              <span class="text-xs tracking-[0.2em] uppercase text-neutral-500" style="font-family: var(--font-family);">{project.category}</span>
            )}
            {keywords.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {keywords.map((kw) => (
                  <span
                    class="text-[0.6rem] tracking-[0.15em] uppercase px-2.5 py-1 border border-neutral-300 text-neutral-500"
                    style="font-family: var(--font-family);"
                  >
                    {kw}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- Collaborators -->
        {collaborators.length > 0 && (
          <div class="py-10">
            <div class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 items-baseline">
              {collaboratorGroups.map((g) => (
                <>
                  <span
                    class="text-xs tracking-[0.2em] uppercase text-neutral-400"
                    style="font-family: var(--font-family);"
                  >
                    {g.profession}
                  </span>
                  <span
                    class="text-sm text-neutral-700"
                    style="font-family: var(--font-family);"
                  >
                    {g.names.join(" · ")}
                  </span>
                </>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>

    <!-- Gallery -->
    {galleryRows.length > 0 && (
      <div class="px-6 md:px-12 lg:px-20 pt-10 pb-10">
        <div class={`${wrapClass} flex flex-col gap-4`}>
          {galleryRows.map((row) =>
            row.type === "solo" ? (
              <div class="w-full overflow-hidden bg-neutral-100">
                <img
                  src={row.img.url}
                  alt={project.title}
                  class="w-full h-auto object-cover"
                  style="max-height: 80vh; object-fit: cover; cursor: zoom-in;"
                  data-lightbox
                  data-lightbox-group="project-gallery"
                />
              </div>
            ) : (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                {row.imgs.map((img) => (
                  <div class="overflow-hidden bg-neutral-100">
                    <img
                      src={img.url}
                      alt={project.title}
                      class="w-full h-full object-cover aspect-4/5"
                      data-lightbox
                      data-lightbox-group="project-gallery"
                      style="cursor:zoom-in;"
                    />
                  </div>
                ))}
              </div>
            )
          )}
        </div>
      </div>
    )}

    <!-- Description -->
    {project.description && (
      <div class="px-6 md:px-12 lg:px-20 pt-10 pb-28">
        <div class={wrapClass}>
          <div
            class="text-lg text-neutral-600 leading-tight [&>p]:mb-4 [&>p:last-child]:mb-0"
            style="font-family: var(--font-family);"
            set:html={descriptionHtml}
          />
        </div>
      </div>
    )}

  </article>

)}

