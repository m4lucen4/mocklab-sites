---
import type { HeaderSlide } from "../types";

interface Props {
  config: HeaderSlide[];
}

const { config } = Astro.props;
const isCarousel = config.length > 1;

function getVimeoSrc(url: string): string | null {
  const match = url.match(/vimeo\.com\/(\d+)/);
  return match ? `https://player.vimeo.com/video/${match[1]}?autoplay=1&muted=1&loop=1&background=1` : null;
}

const s0 = config.length === 1 ? config[0] : null;
const s0IsVimeo = s0?.background_type === "vimeo" && !!s0?.vimeo_url;
const s0VimeoSrc = s0IsVimeo && s0?.vimeo_url ? getVimeoSrc(s0.vimeo_url) : null;
---

<header data-component="header" class="relative w-full h-screen overflow-hidden">
  {isCarousel ? (
    <>
      {config.map((slide, index) => {
        const isVimeo = slide.background_type === "vimeo" && !!slide.vimeo_url;
        const vimeoSrc = isVimeo && slide.vimeo_url ? getVimeoSrc(slide.vimeo_url) : null;
        return (
          <div
            class:list={[
              "carousel-slide absolute inset-0 transition-opacity duration-700",
              index === 0 ? "opacity-100" : "opacity-0",
            ]}
            data-slide-index={index}
          >
            {slide.type === 1 ? (
              <div
                class:list={["relative h-full", isVimeo ? "overflow-hidden bg-black" : "bg-cover bg-center"]}
                style={!isVimeo ? `background-image: url('${slide.image_url}')` : undefined}
              >
                {isVimeo && vimeoSrc && (
                  <div class="absolute inset-0" style="overflow: hidden; pointer-events: none;">
                    <iframe
                      src={vimeoSrc}
                      frameborder="0"
                      allow="autoplay; fullscreen"
                      style="position: absolute; top: 50%; left: 50%; width: 100vw; height: 56.25vw; min-height: 100%; min-width: 177.78vh; transform: translate(-50%, -50%); pointer-events: none;"
                    ></iframe>
                  </div>
                )}
                <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
                <div class="relative z-10 flex flex-col justify-end h-full px-6 md:px-16 pb-12 md:pb-16">
                  <div class="max-w-2xl mx-auto text-center">
                    <h1 class="text-sm md:text-base font-semibold tracking-[0.2em] text-white mb-3" style="font-family: var(--title-font);">{slide.title}</h1>
                    <p class="text-sm md:text-base text-white/80 leading-relaxed mb-6" style="white-space: pre-wrap;">{slide.description}</p>
                    {slide.text_button && slide.url_button && (
                      <a
                        href={slide.url_button}
                        class="inline-block px-6 py-2.5 bg-black/80 text-white text-sm font-medium rounded-full hover:bg-black transition-colors"
                      >
                        {slide.text_button}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ) : (
              <div
                class:list={["relative h-full", isVimeo ? "overflow-hidden bg-black" : "bg-cover bg-center"]}
                style={!isVimeo ? `background-image: url('${slide.image_url}')` : undefined}
              >
                {isVimeo && vimeoSrc && (
                  <div class="absolute inset-0" style="overflow: hidden; pointer-events: none;">
                    <iframe
                      src={vimeoSrc}
                      frameborder="0"
                      allow="autoplay; fullscreen"
                      style="position: absolute; top: 50%; left: 50%; width: 100vw; height: 56.25vw; min-height: 100%; min-width: 177.78vh; transform: translate(-50%, -50%); pointer-events: none;"
                    ></iframe>
                  </div>
                )}
                <div class="absolute inset-0 bg-linear-to-r from-black/50 via-black/20 to-transparent" />
                <div class="relative z-10 flex flex-col justify-end h-full px-6 md:px-16 pb-12 md:pb-16">
                  <div class="max-w-lg">
                    <h1 class="text-sm md:text-base font-semibold tracking-[0.2em] text-white mb-3" style="font-family: var(--title-font);">{slide.title}</h1>
                    <p class="text-sm md:text-base text-white/80 leading-relaxed mb-6" style="white-space: pre-wrap;">{slide.description}</p>
                    {slide.text_button && slide.url_button && (
                      <a
                        href={slide.url_button}
                        class="inline-block px-6 py-2.5 bg-black/80 text-white text-sm font-medium rounded-full hover:bg-black transition-colors"
                      >
                        {slide.text_button}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            )}
          </div>
        );
      })}

      <!-- Carousel arrows -->
      <button
        class="absolute left-5 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center rounded-full border border-white/60 text-white hover:border-white hover:bg-white/10 transition-colors"
        data-carousel-prev
        aria-label="Slide anterior"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button
        class="absolute right-5 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center rounded-full border border-white/60 text-white hover:border-white hover:bg-white/10 transition-colors"
        data-carousel-next
        aria-label="Siguiente slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </>
  ) : s0 ? (
    s0.type === 1 ? (
      <div
        class:list={["carousel-slide relative h-full", s0IsVimeo ? "overflow-hidden bg-black" : "bg-cover bg-center"]}
        style={!s0IsVimeo ? `background-image: url('${s0.image_url}')` : undefined}
        data-slide-index="0"
      >
        {s0IsVimeo && s0VimeoSrc && (
          <div class="absolute inset-0" style="overflow: hidden; pointer-events: none;">
            <iframe
              src={s0VimeoSrc}
              frameborder="0"
              allow="autoplay; fullscreen"
              style="position: absolute; top: 50%; left: 50%; width: 100vw; height: 56.25vw; min-height: 100%; min-width: 177.78vh; transform: translate(-50%, -50%); pointer-events: none;"
            ></iframe>
          </div>
        )}
        <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
        <div class="relative z-10 flex flex-col justify-end h-full px-6 md:px-16 pb-12 md:pb-16">
          <div class="max-w-2xl mx-auto text-center">
            <h1 class="text-sm md:text-base font-semibold tracking-[0.2em] text-white mb-3" style="font-family: var(--title-font);">{s0.title}</h1>
            <p class="text-sm md:text-base text-white/80 leading-relaxed mb-6" style="white-space: pre-wrap;">{s0.description}</p>
            {s0.text_button && s0.url_button && (
              <a
                href={s0.url_button}
                class="inline-block px-6 py-2.5 bg-black/80 text-white text-sm font-medium rounded-full hover:bg-black transition-colors"
              >
                {s0.text_button}
              </a>
            )}
          </div>
        </div>
      </div>
    ) : (
      <div
        class:list={["carousel-slide relative h-full", s0IsVimeo ? "overflow-hidden bg-black" : "bg-cover bg-center"]}
        style={!s0IsVimeo ? `background-image: url('${s0.image_url}')` : undefined}
        data-slide-index="0"
      >
        {s0IsVimeo && s0VimeoSrc && (
          <div class="absolute inset-0" style="overflow: hidden; pointer-events: none;">
            <iframe
              src={s0VimeoSrc}
              frameborder="0"
              allow="autoplay; fullscreen"
              style="position: absolute; top: 50%; left: 50%; width: 100vw; height: 56.25vw; min-height: 100%; min-width: 177.78vh; transform: translate(-50%, -50%); pointer-events: none;"
            ></iframe>
          </div>
        )}
        <div class="absolute inset-0 bg-linear-to-r from-black/50 via-black/20 to-transparent" />
        <div class="relative z-10 flex flex-col justify-end h-full px-6 md:px-16 pb-12 md:pb-16">
          <div class="max-w-lg">
            <h1 class="text-sm md:text-base font-semibold tracking-[0.2em] text-white mb-3" style="font-family: var(--title-font);">{s0.title}</h1>
            <p class="text-sm md:text-base text-white/80 leading-relaxed mb-6" style="white-space: pre-wrap;">{s0.description}</p>
            {s0.text_button && s0.url_button && (
              <a
                href={s0.url_button}
                class="inline-block px-6 py-2.5 bg-black/80 text-white text-sm font-medium rounded-full hover:bg-black transition-colors"
              >
                {s0.text_button}
              </a>
            )}
          </div>
        </div>
      </div>
    )
  ) : null}
</header>
