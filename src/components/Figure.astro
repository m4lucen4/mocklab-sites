---
import type { FigureConfig } from "../types";

interface Props {
  config: FigureConfig;
}

const { config } = Astro.props;
const { image_url, caption, size } = config;
const figClass = size === "half" ? "w-full md:w-1/2 mx-auto" : "w-full";
---

{image_url && (
  <section data-component="figure" class="px-6 md:px-16 py-8">
    <figure class={figClass}>
      <img src={image_url} alt={caption || ""} class="w-full block" />
      {caption && (
        <figcaption class="text-sm mt-3" style="color: var(--color-secondary);">
          {caption}
        </figcaption>
      )}
    </figure>
  </section>
)}
