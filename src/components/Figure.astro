---
import type { FigureConfig } from "../types";

interface Props {
  config: FigureConfig;
}

const { config } = Astro.props;
const { image_url, caption, size, link_url, link_type } = config;
const figClass = size === "half" ? "w-full md:w-1/2 mx-auto" : "w-full";

const href = link_url
  ? link_type === "internal"
    ? `/${link_url}`
    : link_url
  : null;
const isExternal = link_type === "external";
---

{image_url && (
  <section data-component="figure" class="px-6 md:px-16 py-8">
    <figure class={figClass}>
      {href ? (
        <a
          href={href}
          {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
        >
          <img src={image_url} alt={caption || ""} class="w-full block" />
          {caption && (
            <figcaption class="text-base mt-3" style="color: var(--color-primary);">
              {caption}
            </figcaption>
          )}
        </a>
      ) : (
        <>
          <img src={image_url} alt={caption || ""} class="w-full block" />
          {caption && (
            <figcaption class="text-base mt-3" style="color: var(--color-primary);">
              {caption}
            </figcaption>
          )}
        </>
      )}
    </figure>
  </section>
)}
